NODE_ENV=development
PORT=3000

# PostgreSQL — see docker-compose.yml in the repo root for a local instance.
DATABASE_URL="postgresql://forge:forge@localhost:5432/forge?schema=public"

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900           # 15 min, in seconds
JWT_REFRESH_TTL=2592000      # 30 days, in seconds

# OTP / SMS
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5
OTP_DEBUG_EXPOSE=true        # expose code in dev/staging via /auth/otp/debug/:id

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_BASE_URL=http://localhost:3000/uploads
UPLOAD_TTL_HOURS=24

# Feature flags
GEOFENCE_DEFAULT_RADIUS_M=200
WITHDRAWAL_MIN_NAIRA=500
WITHDRAWAL_FLAT_FEE_NAIRA=50
